NEXT_PUBLIC_API_BASE_URL=http://localhost:50037
NEXT_PUBLIC_APP_NAME=AISTalk Demo

# Firebase Anonymous Auth（未設定時はローカル開発向けにトークンなし）
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# 固定ペルソナ（任意）
# NEXT_PUBLIC_SELF_LABEL=あなた
# NEXT_PUBLIC_SELF_VRM_URL=/models/self.vrm
# NEXT_PUBLIC_PERSONA_NAME=アシスタント
# NEXT_PUBLIC_VRM_URL=/models/avatar.vrm
# NEXT_PUBLIC_PERSONA_PERSONALITY=明るく丁寧。短めに話す。
# NEXT_PUBLIC_PERSONA_RESPONSE_STYLE=共感的
