OPENAI_API_KEY=

# Chat
CHAT_MODEL=gpt-4.1-nano
MOTION_MODEL=gpt-4.1-nano
CHAT_TRIM_MAX_TOKENS=3000
CHAT_SYSTEM_PROFILE=single_chat
# CHAT_DEV_ASSIST_SYSTEM=1

APP_PORT=50037

# Auth / Quota
# ローカル開発: AUTH_DISABLED=1 で Firebase 検証をスキップ
AUTH_DISABLED=1
# FIREBASE_PROJECT_ID=
# QUOTA_DISABLED=1
# QUOTA_DAILY_CHAT_LIMIT=30
# QUOTA_DAILY_TTS_LIMIT=30
# GOOGLE_APPLICATION_CREDENTIALS=

# Aivis Speech
# local: AivisSpeech Engine at 127.0.0.1:10101 (default)
# cloud: set AIVIS_MODE=cloud and AIVIS_API_KEY
AIVIS_MODE=local
# AIVIS_API_KEY=
# AIVIS_BASE_URL=https://api.aivis-project.com
# AIVIS_MODEL_UUID=
