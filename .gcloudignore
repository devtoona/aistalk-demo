# gcloud builds submit のアップロード対象から除外（ローカル容量・転送時間削減）
# migrate に必要なのは backend/database/migrations/ 程度

.git/
.gitignore

# 巨大・ローカル専用
coeiroink/
AivisSpeechEngine/

# frontend（db-migrate / backend-build では不要）
frontend/

# backend のローカル成果物
backend/node_modules/
backend/logs/
backend/uploads/
backend/build-server
backend/.env
backend/.env.*

# terraform state / cache
infrastructure/terraform/.terraform/
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.*

# 一般
**/node_modules/
**/.next/
**/dist/
**/.DS_Store
